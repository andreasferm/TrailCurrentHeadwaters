[Unit]
Description=TrailCurrent mDNS Discovery Browser
After=docker.service
Requires=docker.service

[Service]
Type=simple
User=trailcurrent
WorkingDirectory=/home/trailcurrent/local_code
EnvironmentFile=/home/trailcurrent/local_code/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/trailcurrent/local_code/cantomqtt/bin/python /home/trailcurrent/local_code/discovery-mdns.py
Restart=always

[Install]
WantedBy=multi-user.target
