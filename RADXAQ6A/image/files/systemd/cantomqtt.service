[Unit]
Description=CAN bus to MQTT bridge
After=docker.service can0.service
Requires=docker.service
Wants=can0.service
ConditionPathExists=/home/trailcurrent/local_code/can-to-mqtt.py

[Service]
Type=simple
User=trailcurrent
WorkingDirectory=/home/trailcurrent/local_code
EnvironmentFile=-/home/trailcurrent/local_code/.env
ExecStart=/home/trailcurrent/local_code/cantomqtt/bin/python /home/trailcurrent/local_code/can-to-mqtt.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
